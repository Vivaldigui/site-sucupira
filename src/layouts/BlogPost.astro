---
import ArticleHeader from '../components/ArticleHeader.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import InfoBox from '../components/InfoBox.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import ProductCTA from '../components/ProductCTA.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
  BLOG_NAME,
  ORGANIZATION_ID,
  SALES_CTA_URL,
  SALES_SITE_URL,
  SITE_NAME,
  WEBSITE_ID,
  blogAssetUrl,
  blogUrl,
} from '../consts';
import type { FaqItem } from '../utils/faq';
import '../styles/blog.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedPost {
  slug: string;
  title: string;
  description: string;
  tags: string[];
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  slug: string;
  ogImage?: string;
  headings?: Heading[];
  relatedPosts?: RelatedPost[];
  faqItems?: FaqItem[];
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author,
  tags,
  slug,
  ogImage: ogImagePath,
  headings = [],
  relatedPosts = [],
  faqItems = [],
} = Astro.props;

const canonicalUrl = blogUrl(`/${slug}/`);
const ogImage = blogAssetUrl(ogImagePath);
const pageTitle = `${title} | ${SITE_NAME}`;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const heroImage = ogImagePath || '/assets/sucupira-natural-banner.webp';

const graph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': ORGANIZATION_ID,
    name: SITE_NAME,
    url: SALES_SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: blogUrl('/assets/logo.png'),
    },
  },
  {
    '@type': 'WebSite',
    '@id': WEBSITE_ID,
    name: BLOG_NAME,
    url: blogUrl('/'),
    inLanguage: 'pt-BR',
    publisher: { '@id': ORGANIZATION_ID },
  },
  {
    '@type': 'BlogPosting',
    '@id': `${canonicalUrl}#article`,
    url: canonicalUrl,
    headline: title,
    description,
    image: {
      '@type': 'ImageObject',
      url: ogImage,
    },
    author: {
      '@type': 'Organization',
      name: author,
    },
    publisher: { '@id': ORGANIZATION_ID },
    isPartOf: { '@id': WEBSITE_ID },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalUrl,
    },
    datePublished: publishDate.toISOString(),
    dateModified: (updatedDate ?? publishDate).toISOString(),
    inLanguage: 'pt-BR',
    articleSection: tags,
    keywords: tags.join(', '),
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: BLOG_NAME,
        item: blogUrl('/'),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: canonicalUrl,
      },
    ],
  },
];

if (faqItems.length > 0) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${canonicalUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  });
}

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': graph,
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt-BR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <meta property="og:type" content="article" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="article:published_time" content={publishDate.toISOString()} />
    <meta property="article:modified_time" content={(updatedDate ?? publishDate).toISOString()} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <GoogleAnalytics />
    <script type="application/ld+json" set:html={schema}></script>
  </head>
  <body>
    <SiteHeader />

    <nav class="breadcrumb" aria-label="Navegação estrutural">
      <ol>
        <li><a href="/">Centro de Conhecimento</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">{title}</li>
      </ol>
    </nav>

    <ArticleHeader
      title={title}
      description={description}
      publishDate={publishDate}
      updatedDate={updatedDate}
      author={author}
      tags={tags}
      heroImage={heroImage}
    />

    <main class="blog-container">
      <article>
        <InfoBox variant="summary" eyebrow="Em poucas palavras" title="Resumo rápido" labelledBy="quick-summary-title">
          <p>{description}</p>
          {tags.length > 0 && <p class="summary-topics"><strong>Temas:</strong> {tags.join(', ')}.</p>}
        </InfoBox>

        <InfoBox variant="disclaimer" title="Aviso de conteúdo informativo" labelledBy="health-disclaimer-title">
          <p>
            <strong>Não substitui consulta, diagnóstico ou tratamento médico.</strong> Gestantes, lactantes,
            crianças, pessoas com doenças ou em uso de medicamentos devem buscar orientação profissional antes de
            usar produtos ou suplementos.
          </p>
        </InfoBox>

        {tocHeadings.length > 0 && (
          <nav class="article-toc" aria-labelledby="toc-title">
            <h2 id="toc-title">Neste artigo</h2>
            <ol>
              {tocHeadings.map((heading) => (
                <li class:list={{ 'toc-level-3': heading.depth === 3 }}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        )}

        <div class="article-body">
          <slot />
        </div>

        <ProductCTA
          variant="inline"
          title="Quer ver a Sucupira Naturale?"
          text="Conheça o produto na página oficial, com as informações comerciais separadas do conteúdo educativo."
          label="Ver Sucupira Naturale"
        />

        <RelatedArticles posts={relatedPosts} />

        <InfoBox variant="transparency" title="Transparência editorial" labelledBy="transparency-title">
          <p>
            Este conteúdo educativo é preparado pela {author} a partir de literatura pública e fontes
            informativas. Não declaramos revisão médica quando ela não ocorreu e o material não substitui
            orientação individual de um profissional de saúde.
          </p>
        </InfoBox>

        <ProductCTA
          title="Quer conhecer a Sucupira Naturale?"
          text="Consulte opções, condições e informações do produto na página oficial de venda. O conteúdo deste artigo permanece exclusivamente informativo."
          label="Acessar página oficial"
        />

        <aside class="author-box" aria-label="Sobre a autoria">
          <div class="author-avatar" aria-hidden="true">SN</div>
          <div class="author-info">
            <h2>{author}</h2>
            <p>
              Equipe responsável pela organização dos conteúdos educativos da Sucupira Naturale. Nenhuma
              credencial médica ou revisão clínica é atribuída sem comprovação.
            </p>
          </div>
        </aside>

        <footer class="article-footer-note">
          <strong>Aviso:</strong> Conteúdo exclusivamente informativo. Não substitui consulta, diagnóstico ou
          tratamento médico.
          <nav aria-label="Links finais do artigo">
            <a href="/">← Voltar ao Centro de Conhecimento</a>
            <span aria-hidden="true">·</span>
            <a href={SALES_CTA_URL}>Página oficial do produto</a>
          </nav>
        </footer>
      </article>
    </main>

    <footer class="blog-footer">
      <p>© 2016–{new Date().getFullYear()} Sucupira Naturale — Todos os direitos reservados.</p>
      <p><a href={SALES_CTA_URL}>Acessar a página oficial do produto</a></p>
    </footer>

    <MobileStickyCTA />
  </body>
</html>
