---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BlogHero from '../components/BlogHero.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
  BLOG_NAME,
  BLOG_SITE_URL,
  DEFAULT_OG_IMAGE,
  ORGANIZATION_ID,
  SALES_CTA_URL,
  SALES_SITE_URL,
  SITE_NAME,
  WEBSITE_ID,
  blogUrl,
} from '../consts';
import '../styles/blog.css';
import { getPublishedPosts } from '../utils/posts';

const posts = getPublishedPosts(await getCollection('blog'));

const tags = [...new Set(posts.flatMap((post) => post.data.tags))]
  .map((name) => ({
    name,
    count: posts.filter((post) => post.data.tags.includes(name)).length,
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'pt-BR'));

const canonicalUrl = blogUrl('/');
const title = `${BLOG_NAME} | ${SITE_NAME}`;
const description =
  'Conteúdo educativo sobre sucupira, formas de uso, evidências disponíveis e cuidados, organizado pela Equipe Sucupira Naturale.';

const searchIndex = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  slug: post.slug,
}));

const serializedSearchIndex = JSON.stringify(searchIndex).replace(/</g, '\\u003c');

const defaultCardImage = '/assets/sucupira-natural-banner.webp';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': ORGANIZATION_ID,
      name: SITE_NAME,
      url: SALES_SITE_URL,
      logo: {
        '@type': 'ImageObject',
        url: blogUrl('/assets/logo.png'),
      },
    },
    {
      '@type': 'WebSite',
      '@id': WEBSITE_ID,
      name: BLOG_NAME,
      url: canonicalUrl,
      inLanguage: 'pt-BR',
      publisher: { '@id': ORGANIZATION_ID },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${BLOG_SITE_URL}/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'CollectionPage',
      '@id': `${canonicalUrl}#collection`,
      name: BLOG_NAME,
      description,
      url: canonicalUrl,
      inLanguage: 'pt-BR',
      isPartOf: { '@id': WEBSITE_ID },
      about: tags.map((tag) => tag.name),
      mainEntity: {
        '@type': 'ItemList',
        numberOfItems: posts.length,
        itemListElement: posts.map((post, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          url: blogUrl(`/${post.slug}/`),
          name: post.data.title,
        })),
      },
    },
  ],
});

---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt-BR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={DEFAULT_OG_IMAGE} />
    <meta property="og:image:alt" content="Extrato de sucupira da Sucupira Naturale" />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={DEFAULT_OG_IMAGE} />
    <meta name="twitter:image:alt" content="Extrato de sucupira da Sucupira Naturale" />

    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <GoogleAnalytics />
    <script type="application/ld+json" set:html={schema}></script>
  </head>
  <body>
    <SiteHeader />
    <BlogHero />

    <main class="knowledge-main">
      <section class="knowledge-tools" aria-label="Buscar artigos">
        <form class="knowledge-search" role="search" action="/" method="get">
          <label for="knowledge-search" class="visually-hidden">Buscar nos artigos</label>
          <div class="search-row">
            <input
              id="knowledge-search"
              name="q"
              type="search"
              placeholder="Busque por tema, título ou palavra-chave"
              autocomplete="off"
            />
            <button type="submit">Buscar</button>
          </div>
        </form>

        <p id="search-status" class="search-status visually-hidden" aria-live="polite">
          {posts.length} {posts.length === 1 ? 'artigo encontrado' : 'artigos encontrados'}
        </p>
      </section>

      <section aria-labelledby="articles-title">
        <h2 id="articles-title" class="visually-hidden">Artigos publicados</h2>
        {posts.length === 0 ? (
          <p class="empty-state">Nenhum artigo publicado ainda.</p>
        ) : (
          <div class="posts-grid" id="posts-grid">
            {posts.map((post) => (
              <ArticleCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                tags={post.data.tags}
                publishDate={post.data.publishDate}
                image={post.data.ogImage || defaultCardImage}
              />
            ))}
          </div>
        )}
        <p id="no-results" class="empty-state" hidden>
          Nenhum artigo corresponde à busca.
        </p>
      </section>
    </main>

    <footer class="blog-footer">
      <p>© 2016–{new Date().getFullYear()} Sucupira Naturale — Todos os direitos reservados.</p>
      <p><a href={SALES_CTA_URL}>Acessar a página oficial do produto</a></p>
    </footer>

    <script id="search-index" type="application/json" set:html={serializedSearchIndex}></script>
    <script>
      const searchDataElement = document.querySelector('#search-index');
      const searchInput = document.querySelector('#knowledge-search');
      const searchForm = document.querySelector('.knowledge-search');
      const status = document.querySelector('#search-status');
      const noResults = document.querySelector('#no-results');
      const cards = [...document.querySelectorAll('[data-post-card]')];

      if (searchDataElement && searchInput instanceof HTMLInputElement) {
        const posts = JSON.parse(searchDataElement.textContent || '[]');
        const params = new URLSearchParams(window.location.search);
        searchInput.value = params.get('q') || '';

        const normalize = (value) =>
          value
            .normalize('NFD')
            .replace(/[̀-ͯ]/g, '')
            .toLocaleLowerCase('pt-BR');

        const syncUrl = () => {
          const nextParams = new URLSearchParams();
          const query = searchInput.value.trim();
          if (query) nextParams.set('q', query);
          const queryString = nextParams.toString();
          window.history.replaceState({}, '', queryString ? `/?${queryString}` : '/');
        };

        const applyFilters = () => {
          const query = normalize(searchInput.value.trim());
          let visibleCount = 0;

          posts.forEach((post) => {
            const searchable = normalize(
              [post.title, post.description, post.slug, ...post.tags].join(' ')
            );
            const visible = !query || searchable.includes(query);
            const card = cards.find((item) => item.getAttribute('data-slug') === post.slug);
            if (card) card.toggleAttribute('hidden', !visible);
            if (visible) visibleCount += 1;
          });

          if (status) {
            status.textContent = `${visibleCount} ${
              visibleCount === 1 ? 'artigo encontrado' : 'artigos encontrados'
            }`;
          }
          if (noResults) noResults.toggleAttribute('hidden', visibleCount !== 0);
          syncUrl();
        };

        searchInput.addEventListener('input', applyFilters);
        searchForm?.addEventListener('submit', (event) => {
          event.preventDefault();
          applyFilters();
        });

        applyFilters();
      }
    </script>
  </body>
</html>
