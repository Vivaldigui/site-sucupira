---
import { getCollection } from 'astro:content';
import { blogUrl } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = getPublishedPosts(await getCollection('blog'));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { target: blogUrl(`/${post.slug}/`) },
  }));
}

const { target } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecionando para o artigo</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
  </head>
  <body>
    <p>Este artigo mudou de endereço. <a href={target}>Continuar para o conteúdo</a>.</p>
  </body>
</html>
