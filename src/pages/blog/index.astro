---
import { blogUrl } from '../../consts';

const target = blogUrl('/');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecionando para o Centro de Conhecimento</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
  </head>
  <body>
    <p>O blog agora está em <a href={target}>{target}</a>.</p>
  </body>
</html>
